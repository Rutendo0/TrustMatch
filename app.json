{
  "expo": {
    "name": "TrustMatch",
    "slug": "trust-match",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#DC2626"
    },
    "updates": {
      "url": "https://u.expo.dev/4445c7cb-0ea3-44b6-b75e-76055cac64bb",
      "enabled": false
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trustmatch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "TrustMatch needs camera access for identity verification and profile photos.",
        "NSPhotoLibraryUsageDescription": "TrustMatch needs photo library access for profile photos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#DC2626"
      },
      "package": "com.trustmatch.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "TrustMatch needs camera access for identity verification."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "TrustMatch uses your location to share with your emergency contact for safety."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "4445c7cb-0ea3-44b6-b75e-76055cac64bb"
      }
    },
    "owner": "makasimb"
  }
}
