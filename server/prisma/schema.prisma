generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String              @id @default(uuid())
  email               String              @unique
  phone               String              @unique
  passwordHash        String
  firstName           String
  lastName            String
  dateOfBirth         DateTime
  gender              Gender
  interestedIn        InterestedIn
  bio                 String?
  occupation          String?
  education           String?
  relationshipGoal    String?
  aboutMe             String?
  interests           String?  // Stored as JSON string array
  city                String?
  country             String?
  latitude            Float?
  longitude           Float?
  role                UserRole            @default(USER)
  ageRangeMin         Int                 @default(18)
  ageRangeMax         Int                 @default(50)
  maxDistance         Int                 @default(50)
  isActive            Boolean             @default(true)
  lastActive          DateTime            @default(now())
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  clerkId             String?             @unique
  status              UserStatus          @default(PENDING)
  dateJournals        DateJournal[]
  deviceFingerprints  DeviceFingerprint[]
  createdEvents       Event[]
  eventAttendees      EventAttendee[]
  matches1            Match[]             @relation("MatchUser1")
  matches2            Match[]             @relation("MatchUser2")
  sentMessages        Message[]           @relation("SentMessages")
  photos              Photo[]
  refreshTokens       RefreshToken[]
  partnerRelationship RelationshipMode?   @relation("PartnerUser")
  primaryRelationship RelationshipMode?   @relation("PrimaryUser")
  receivedSwipes      Swipe[]             @relation("ReceivedSwipes")
  sentSwipes          Swipe[]             @relation("SentSwipes")
  blockedBy           UserBlock[]         @relation("BlockedUser")
  blockedUsers        UserBlock[]         @relation("BlockingUser")
  reportsReceived     UserReport[]        @relation("ReportsReceived")
  reportsMade         UserReport[]        @relation("ReportsMade")
  verification        Verification?
  reviewsReceived     VerifiedReview[]    @relation("ReviewsReceived")
  reviewsGiven        VerifiedReview[]    @relation("ReviewsGiven")
  voiceNotes          VoiceNote[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model UserBlock {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())
  blocked   User     @relation("BlockedUser", fields: [blockedId], references: [id], onDelete: Cascade)
  blocker   User     @relation("BlockingUser", fields: [blockerId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

model Verification {
  id                  String              @id @default(uuid())
  userId              String              @unique
  isVerified          Boolean             @default(false)
  idVerified          Boolean             @default(false)
  selfieVerified      Boolean             @default(false)
  emailVerified       Boolean             @default(false)
  phoneVerified       Boolean             @default(false)
  liveVerified        Boolean             @default(false)
  lastLiveVerification DateTime?
  liveVerificationCount Int               @default(0)
  idDocumentType      IDDocumentType?
  idDocumentUrl       String?
  selfieUrl           String?
  faceMatchScore      Float?
  livenessScore       Float?
  verifiedAt          DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  emailCode           String?
  emailCodeExpiry     DateTime?
  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  liveVerificationHistory LiveVerification[]
}

model LiveVerification {
  id              String      @id @default(uuid())
  verificationId  String
  similarity      Float
  confidence      Float
  isMatch         Boolean
  photosMatched   Int
  totalPhotos     Int
  ipAddress       String?
  deviceInfo      String?
  createdAt       DateTime    @default(now())
  verification    Verification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@index([createdAt])
}

model DeviceFingerprint {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String
  platform   String
  osVersion  String?
  appVersion String?
  ipAddress  String?
  isBlocked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([deviceId, userId])
  @@index([deviceId])
}

model Photo {
  id        String   @id @default(uuid())
  userId    String
  url       String
  order     Int      @default(0)
  isMain    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Swipe {
  id        String      @id @default(uuid())
  swiperId  String
  swipedId  String
  action    SwipeAction
  createdAt DateTime    @default(now())
  swiped    User        @relation("ReceivedSwipes", fields: [swipedId], references: [id], onDelete: Cascade)
  swiper    User        @relation("SentSwipes", fields: [swiperId], references: [id], onDelete: Cascade)

  @@unique([swiperId, swipedId])
  @@index([swipedId])
}

model Match {
  id           String           @id @default(uuid())
  user1Id      String
  user2Id      String
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  dateJournals DateJournal[]
  user1        User             @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2        User             @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  messages     Message[]
  reviews      VerifiedReview[]

  @@unique([user1Id, user2Id])
}

model Message {
  id        String         @id @default(uuid())
  matchId   String
  senderId  String
  content   String
  type      MessageType    @default(TEXT)
  readAt    DateTime?
  createdAt DateTime       @default(now())
  match     Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  sender    User           @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  status    MessageStatus?

  @@index([matchId])
}

model BlockedAccount {
  id        String   @id @default(uuid())
  email     String?
  phone     String?
  deviceId  String?
  reason    String
  blockedAt DateTime @default(now())

  @@index([email])
  @@index([phone])
  @@index([deviceId])
}

model VoiceNote {
  id         String   @id @default(uuid())
  userId     String
  audioUrl   String
  duration   Int
  transcript String?
  prompt     String?
  isActive   Boolean  @default(true)
  playCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Event {
  id               String          @id @default(uuid())
  creatorId        String
  title            String
  description      String
  category         EventCategory
  eventType        EventType
  venueName        String?
  address          String?
  latitude         Float?
  longitude        Float?
  isVirtual        Boolean         @default(false)
  startDateTime    DateTime
  endDateTime      DateTime
  timezone         String          @default("UTC")
  maxAttendees     Int?
  isPublic         Boolean         @default(true)
  requiresApproval Boolean         @default(false)
  interestTags     String[]
  imageUrl         String?
  isActive         Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  creator          User            @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  attendees        EventAttendee[]

  @@index([creatorId])
  @@index([category])
  @@index([eventType])
  @@index([startDateTime])
  @@index([latitude, longitude])
}

model EventAttendee {
  id       String         @id @default(uuid())
  eventId  String
  userId   String
  status   AttendeeStatus @default(PENDING)
  joinedAt DateTime       @default(now())
  event    Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model DateJournal {
  id            String    @id @default(uuid())
  matchId       String
  userId        String
  dateTitle     String?
  dateLocation  String?
  dateTime      DateTime?
  notes         String?
  moodRating    Int?
  wouldSeeAgain Boolean?
  memoryTags    String[]
  photoUrls     String[]
  isPrivate     Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  match         Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
}

model RelationshipMode {
  id              String             @id @default(uuid())
  primaryUserId   String             @unique
  partnerUserId   String             @unique
  isActive        Boolean            @default(true)
  startedAt       DateTime           @default(now())
  anniversaryDate DateTime?
  status          RelationshipStatus @default(ACTIVE)
  discoveryPaused Boolean            @default(true)
  profileVisible  Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  partnerUser     User               @relation("PartnerUser", fields: [partnerUserId], references: [id], onDelete: Cascade)
  primaryUser     User               @relation("PrimaryUser", fields: [primaryUserId], references: [id], onDelete: Cascade)

  @@index([primaryUserId])
  @@index([partnerUserId])
}

model VerifiedReview {
  id                  String    @id @default(uuid())
  reviewerId          String
  reviewedId          String
  matchId             String
  profileAccuracy     Int
  conversationQuality Int
  authenticity        Int
  punctuality         Int?
  chemistry           Int?
  overallRating       Float
  positives           String[]
  improvements        String[]
  additionalComments  String?
  isVerified          Boolean   @default(false)
  verifiedAt          DateTime?
  isFlagged           Boolean   @default(false)
  flagReason          String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  match               Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  reviewed            User      @relation("ReviewsReceived", fields: [reviewedId], references: [id], onDelete: Cascade)
  reviewer            User      @relation("ReviewsGiven", fields: [reviewerId], references: [id], onDelete: Cascade)

  @@index([reviewedId])
  @@index([reviewerId])
  @@index([matchId])
  @@index([createdAt])
}

model MessageStatus {
  id              String    @id @default(uuid())
  messageId       String    @unique
  isRead          Boolean   @default(false)
  readAt          DateTime?
  isTyping        Boolean   @default(false)
  typingStartedAt DateTime?
  typingEndedAt   DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  message         Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model UserReport {
  id         String       @id @default(uuid())
  reporterId String
  reportedId String
  reason     ReportReason
  details    String?
  matchId    String?
  status     ReportStatus @default(PENDING)
  reviewedAt DateTime?
  reviewedBy String?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  reported   User         @relation("ReportsReceived", fields: [reportedId], references: [id], onDelete: Cascade)
  reporter   User         @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([reportedId])
  @@index([reporterId])
  @@index([status])
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
}

enum InterestedIn {
  MALE
  FEMALE
}

enum IDDocumentType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
}

enum SwipeAction {
  LIKE
  DISLIKE
  SUPERLIKE
}

enum MessageType {
  TEXT
  IMAGE
  GIF
  VOICE_NOTE
}

enum EventCategory {
  FOOD_DRINKS
  OUTDOOR_ADVENTURE
  ARTS_CULTURE
  FITNESS_WELLNESS
  MUSIC_ENTERTAINMENT
  TRAVEL_EXPLORATION
  TECH_INNOVATION
  BOOKS_LEARNING
  VOLUNTEER_SOCIAL
  DATING_RELATIONSHIPS
  OTHER
}

enum EventType {
  VIRTUAL
  IN_PERSON
  HYBRID
}

enum AttendeeStatus {
  PENDING
  CONFIRMED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum RelationshipStatus {
  ACTIVE
  PAUSED
  ENDED
}

enum ReportReason {
  FAKE_PROFILE
  INAPPROPRIATE_CONTENT
  HARASSMENT
  SPAM
  UNDERAGE
  SCAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
  DISMISSED
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
}
