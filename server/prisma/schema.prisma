generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  phone             String    @unique
  passwordHash      String
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            Gender
  interestedIn      InterestedIn
  bio               String?
  city              String?
  country           String?
  latitude          Float?
  longitude         Float?
  
  verification      Verification?
  deviceFingerprints DeviceFingerprint[]
  photos            Photo[]
  sentSwipes        Swipe[]   @relation("SentSwipes")
  receivedSwipes    Swipe[]   @relation("ReceivedSwipes")
  matches1          Match[]   @relation("MatchUser1")
  matches2          Match[]   @relation("MatchUser2")
  sentMessages      Message[] @relation("SentMessages")
  
  ageRangeMin       Int       @default(18)
  ageRangeMax       Int       @default(50)
  maxDistance       Int       @default(50)
  
  isActive          Boolean   @default(true)
  lastActive        DateTime  @default(now())
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model Verification {
  id              String    @id @default(uuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  isVerified      Boolean   @default(false)
  idVerified      Boolean   @default(false)
  selfieVerified  Boolean   @default(false)
  emailVerified   Boolean   @default(false)
  phoneVerified   Boolean   @default(false)
  
  idDocumentType  IDDocumentType?
  idDocumentUrl   String?
  selfieUrl       String?
  faceMatchScore  Float?
  livenessScore   Float?
  
  verifiedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model DeviceFingerprint {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  deviceId        String
  platform        String
  osVersion       String?
  appVersion      String?
  ipAddress       String?
  
  isBlocked       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  lastUsedAt      DateTime  @default(now())
  
  @@unique([deviceId, userId])
  @@index([deviceId])
}

model Photo {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  url         String
  order       Int       @default(0)
  isMain      Boolean   @default(false)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Swipe {
  id            String    @id @default(uuid())
  swiperId      String
  swiper        User      @relation("SentSwipes", fields: [swiperId], references: [id], onDelete: Cascade)
  swipedId      String
  swiped        User      @relation("ReceivedSwipes", fields: [swipedId], references: [id], onDelete: Cascade)
  
  action        SwipeAction
  createdAt     DateTime  @default(now())
  
  @@unique([swiperId, swipedId])
  @@index([swipedId])
}

model Match {
  id          String    @id @default(uuid())
  user1Id     String
  user1       User      @relation("MatchUser1", fields: [user1Id], references: [id], onDelete: Cascade)
  user2Id     String
  user2       User      @relation("MatchUser2", fields: [user2Id], references: [id], onDelete: Cascade)
  
  messages    Message[]
  
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  
  @@unique([user1Id, user2Id])
}

model Message {
  id          String    @id @default(uuid())
  matchId     String
  match       Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  senderId    String
  sender      User      @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  
  content     String
  type        MessageType @default(TEXT)
  
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  
  @@index([matchId])
}

model BlockedAccount {
  id              String    @id @default(uuid())
  email           String?
  phone           String?
  deviceId        String?
  reason          String
  blockedAt       DateTime  @default(now())
  
  @@index([email])
  @@index([phone])
  @@index([deviceId])
}

model VoiceNote {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  audioUrl    String
  duration    Int       // in seconds
  transcript  String?
  prompt      String?   // what this voice note is in response to
  
  isActive    Boolean   @default(true)
  playCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@index([userId])
  @@index([createdAt])
}

model Event {
  id              String    @id @default(uuid())
  creatorId       String
  creator         User      @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  
  title           String
  description     String
  category        EventCategory
  eventType       EventType
  
  // Location info
  venueName       String?
  address         String?
  latitude        Float?
  longitude       Float?
  isVirtual       Boolean   @default(false)
  
  // Event timing
  startDateTime   DateTime
  endDateTime     DateTime
  timezone        String    @default("UTC")
  
  // Capacity and access
  maxAttendees    Int?
  isPublic        Boolean   @default(true)
  requiresApproval Boolean  @default(false)
  
  // Event metadata
  interestTags    String[]  // e.g., ["travel", "food", "fitness"]
  imageUrl        String?
  
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  attendees       EventAttendee[]
  
  @@index([creatorId])
  @@index([category])
  @@index([eventType])
  @@index([startDateTime])
  @@index([latitude, longitude])
}

model EventAttendee {
  id              String    @id @default(uuid())
  eventId         String
  event           Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  status          AttendeeStatus @default(PENDING)
  joinedAt        DateTime  @default(now())
  
  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model DateJournal {
  id              String    @id @default(uuid())
  matchId         String
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  dateTitle       String?
  dateLocation    String?
  dateTime        DateTime?
  
  // Private notes
  notes           String?   // Private thoughts about the date
  moodRating      Int?      // 1-5 scale
  wouldSeeAgain   Boolean?
  
  // Memories and photos
  memoryTags      String[]  // e.g., ["funny", "romantic", "adventurous"]
  photoUrls       String[]
  
  isPrivate       Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
}

model RelationshipMode {
  id              String    @id @default(uuid())
  // This represents a couple who met through the app
  primaryUserId   String
  partnerUserId   String
  
  isActive        Boolean   @default(true)
  startedAt       DateTime  @default(now())
  
  // Relationship details
  anniversaryDate DateTime?
  status          RelationshipStatus @default(ACTIVE)
  
  // Settings
  discoveryPaused Boolean   @default(true)
  profileVisible  Boolean   @default(false)
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@unique([primaryUserId, partnerUserId])
  @@index([primaryUserId])
  @@index([partnerUserId])
}

model VerifiedReview {
  id              String    @id @default(uuid())
  reviewerId      String
  reviewer        User      @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  reviewedId      String
  
  matchId         String    // The match this review is about
  match           Match     @relation(fields: [matchId], references: [id], onDelete: Cascade)
  
  // Review categories
  profileAccuracy Int       // 1-5: How accurate was their profile?
  conversationQuality Int   // 1-5: Quality of conversation
  authenticity     Int      // 1-5: How authentic did they seem?
  punctuality      Int?     // 1-5: Were they on time?
  chemistry        Int?     // 1-5: Was there chemistry?
  
  overallRating   Float     // 1-5 overall experience
  
  // Detailed feedback
  positives       String[]  // What went well
  improvements    String[]  // Areas for improvement
  additionalComments String?
  
  // Verification
  isVerified      Boolean   @default(false) // Verified through mutual match confirmation
  verifiedAt      DateTime?
  
  // Moderation
  isFlagged       Boolean   @default(false)
  flagReason      String?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([reviewedId])
  @@index([reviewerId])
  @@index([matchId])
  @@index([createdAt])
}

model MessageStatus {
  id              String    @id @default(uuid())
  messageId       String    @unique
  message         Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  
  isRead          Boolean   @default(false)
  readAt          DateTime?
  
  // Typing indicator
  isTyping        Boolean   @default(false)
  typingStartedAt DateTime?
  typingEndedAt   DateTime?
  
  // Delivery status
  deliveredAt     DateTime?
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@index([messageId])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum InterestedIn {
  MALE
  FEMALE
  BOTH
}

enum IDDocumentType {
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
}

enum SwipeAction {
  LIKE
  DISLIKE
  SUPERLIKE
}

enum MessageType {
  TEXT
  IMAGE
  GIF
  VOICE_NOTE
}

enum EventCategory {
  FOOD_DRINKS
  OUTDOOR_ADVENTURE
  ARTS_CULTURE
  FITNESS_WELLNESS
  MUSIC_ENTERTAINMENT
  TRAVEL_EXPLORATION
  TECH_INNOVATION
  BOOKS_LEARNING
  VOLUNTEER_SOCIAL
  DATING_RELATIONSHIPS
  OTHER
}

enum EventType {
  VIRTUAL
  IN_PERSON
  HYBRID
}

enum AttendeeStatus {
  PENDING
  CONFIRMED
  ATTENDED
  CANCELLED
  NO_SHOW
}

enum RelationshipStatus {
  ACTIVE
  PAUSED
  ENDED
}
