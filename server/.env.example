# Database
DATABASE_URL="postgresql://user:password@localhost:5432/trustmatch?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=3000
NODE_ENV=development

# AI Verification API (e.g., Onfido, Jumio, or similar)
VERIFICATION_API_KEY="your-verification-api-key"
VERIFICATION_API_URL="https://api.verification-provider.com"

# AWS S3 or similar for file storage
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_BUCKET_NAME="trustmatch-uploads"
AWS_REGION="us-east-1"
